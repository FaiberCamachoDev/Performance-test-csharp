<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportManager</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="sm-navbar">
        <div class="sm-navbar-inner">
            <a class="sm-brand" asp-controller="Home" asp-action="Index">
                <span class="sm-brand-icon"><i class="bi bi-lightning-charge-fill"></i></span>
                Sport<span>Manager</span>
            </a>
            <ul class="sm-nav-links">
                <li><a class="sm-nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a class="sm-nav-link" asp-controller="Users" asp-action="Index">Members</a></li>
                <li><a class="sm-nav-link" asp-controller="DeportiveSpace" asp-action="Index">Venues</a></li>
                <li>
                    <a class="sm-nav-cta" asp-controller="Reservations" asp-action="Index">
                        <i class="bi bi-calendar-check-fill"></i> Bookings
                    </a>
                </li>
            </ul>
            <button class="sm-nav-toggle" onclick="document.getElementById('mobileMenu').classList.toggle('open')" aria-label="Menu">
                <i class="bi bi-list"></i>
            </button>
        </div>
    </nav>

    <div id="mobileMenu" class="sm-mobile-menu">
        <a class="sm-nav-link" asp-controller="Home" asp-action="Index">Home</a>
        <a class="sm-nav-link" asp-controller="Users" asp-action="Index">Members</a>
        <a class="sm-nav-link" asp-controller="DeportiveSpace" asp-action="Index">Venues</a>
        <a class="sm-nav-cta" asp-controller="Reservations" asp-action="Index">
            <i class="bi bi-calendar-check-fill"></i> Bookings
        </a>
    </div>

    <div class="sm-page">
        <div class="sm-container">
            <main>@RenderBody()</main>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>