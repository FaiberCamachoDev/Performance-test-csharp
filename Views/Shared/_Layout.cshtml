<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportManager</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="sm-navbar">
        <div class="container">
            <a class="sm-brand" asp-controller="Home" asp-action="Index">
                <span class="sm-brand-icon"><i class="bi bi-lightning-charge-fill"></i></span>
                Sport<span>Manager</span>
            </a>

            <ul class="sm-nav-links">
                <li><a class="sm-nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a class="sm-nav-link" asp-controller="Users" asp-action="Index">Members</a></li>
                <li><a class="sm-nav-link" asp-controller="DeportiveSpace" asp-action="Index">Venues</a></li>
                <li>
                    <a class="sm-nav-cta" asp-controller="Reservations" asp-action="Index">
                        <i class="bi bi-calendar-check-fill"></i> Bookings
                    </a>
                </li>
            </ul>

            <button class="navbar-toggler-custom" type="button" onclick="toggleMobileNav()" aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>
        </div>
    </nav>

    <!-- Mobile nav -->
    <div id="smMobileNav" class="sm-nav-mobile" style="display:none; position:fixed; top:72px; left:0; right:0; background:white; border-bottom:1px solid var(--border); padding:1rem; z-index:999; box-shadow:var(--shadow-md);">
        <ul style="list-style:none; display:flex; flex-direction:column; gap:4px;">
            <li><a class="sm-nav-link" asp-controller="Home" asp-action="Index" style="display:block;">Home</a></li>
            <li><a class="sm-nav-link" asp-controller="Users" asp-action="Index" style="display:block;">Members</a></li>
            <li><a class="sm-nav-link" asp-controller="DeportiveSpace" asp-action="Index" style="display:block;">Venues</a></li>
            <li style="margin-top:8px;"><a class="sm-btn sm-btn-primary sm-btn-block" asp-controller="Reservations" asp-action="Index"><i class="bi bi-calendar-check-fill"></i> Bookings</a></li>
        </ul>
    </div>

    <div class="sm-page">
        <div class="container">
            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        function toggleMobileNav() {
            var nav = document.getElementById('smMobileNav');
            nav.style.display = nav.style.display === 'none' ? 'block' : 'none';
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>