@model IEnumerable<Performance_test_csharp.Models.Reservation>

<div class="sm-section-header sm-animate">
    <div>
        <h2 class="sm-section-title">Bookings</h2>
        <p class="sm-section-sub">All scheduled reservations across all venues.</p>
    </div>
    <a asp-action="Create" class="sm-btn sm-btn-primary">
        <i class="bi bi-calendar-plus-fill"></i> New Booking
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="sm-alert-success sm-animate" style="
        background: rgba(22,163,74,0.08);
        border: 1px solid rgba(22,163,74,0.25);
        color: var(--brand);
        border-radius: var(--radius-sm);
        padding: 12px 16px;
        font-size: .9rem;
        font-weight: 500;
        margin-bottom: 1.25rem;
        display: flex; align-items: center; gap: 8px;">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="sm-alert-error sm-animate" style="margin-bottom: 1.25rem;">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

<div class="sm-card sm-animate sm-animate-d1">
    <div class="sm-table-wrap">
        <table class="sm-table">
            <thead>
                <tr>
                    <th>Member</th>
                    <th>Venue</th>
                    <th>Date</th>
                    <th>Time Slot</th>
                    <th style="text-align:center">Status</th>
                    <th style="text-align:center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align:center; padding:3rem; color:var(--text-muted);">
                            <i class="bi bi-calendar-x" style="font-size:2rem; display:block; margin-bottom:.5rem;"></i>
                            No bookings registered yet.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    var statusClass = item.Status switch {
                        "Active"    => "sm-status-active",
                        "Cancelled" => "sm-status-cancelled",
                        "Finished"  => "sm-status-finished",
                        _           => "sm-status-inactive"
                    };
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div class="sm-avatar">
                                    @(item.User?.Name.Length > 0 ? item.User.Name[0].ToString().ToUpper() : "?")
                                </div>
                                <span style="font-weight:600;">@(item.User?.Name ?? "—")</span>
                            </div>
                        </td>
                        <td>
                            <span class="sm-pill sm-pill-green">@(item.SportSpace?.Name ?? "—")</span>
                        </td>
                        <td class="sm-td-muted">
                            <i class="bi bi-calendar3" style="margin-right:5px;"></i>
                            @item.Date.ToString("MMM dd, yyyy")
                        </td>
                        <td class="sm-td-muted">
                            <i class="bi bi-clock" style="margin-right:5px;"></i>
                            @item.StartTime.ToString(@"hh\:mm") – @item.FinishTime.ToString(@"hh\:mm")
                        </td>
                        <td style="text-align:center;">
                            <span class="sm-status @statusClass">@item.Status</span>
                        </td>
                        <td style="text-align:center;">
                            @if (item.Status == "Active")
                            {
                                <form asp-action="Cancel" asp-route-id="@item.Id" method="post"
                                      onsubmit="return confirm('Cancel this booking?');"
                                      style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="sm-btn sm-btn-danger-ghost sm-btn-sm">
                                        <i class="bi bi-x-circle"></i> Cancel
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span style="color:var(--text-muted); font-size:.82rem;">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>